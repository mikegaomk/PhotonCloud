# Database
DATABASE_URL=postgresql+asyncpg://photoncloud:password@localhost:5432/photoncloud

# OpenAI (required for AI enrichment)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# RSS Scheduler
RSS_FETCH_INTERVAL_HOURS=6
RSS_FETCH_TIMEOUT_SECONDS=30

# News API
NEWS_PAGE_SIZE_MAX=100
NEWS_RETENTION_DAYS=365

# Auth
AUTH_SECRET_KEY=photoncloud-dev-secret
